# Sources library and exits with good info in case of not being able to source
source_lib()
{
    local lib="$1"

    local func_call_file
    func_call_file="$(basename "${BASH_SOURCE[1]}")"

    local error_info
    error_info="File '$func_call_file' requires library '$(basename "$lib")'"

    if ! [[ -f "$lib" ]]
    then
        echo "$error_info"
        echo "Necessary library does not exist: '$lib'"
        return 1
    fi

    if ! source "$lib"
    then
        echo "$error_info"
        echo "Could not source library even though the file exists: '$lib'"
        return 1
    fi
}

export -f source_lib

modify_path()
{
    local position="$1"  # "append" or "prepend"
    local new_path="$2"

    case "$position" in
        'append'|'prepend') ;;
        *)
            echo "ERROR: modify_path - Invalid position: '$position'"
            return 1
            ;;
    esac

    if [[ ! -d "$new_path" ]]
    then
        echo "ERROR: $position - Path is not a directory: '$new_path'"
        return 1
    fi

    # Check if already in PATH
    echo "$PATH" | tr ':' '\n' | grep -q "^$new_path\$" &&
        return 0

    case "$position" in
        'append')
            PATH="${PATH:+${PATH}:}${new_path}"
            ;;
        'prepend')
            PATH="${new_path}${PATH:+:${PATH}}"
            ;;
    esac

    export PATH
}

append_to_path()
{
    local new_path="$1"

    modify_path 'append' "$new_path"
}

prepend_to_path()
{
    local new_path="$1"

    modify_path 'prepend' "$new_path"
}

