    rb = rebase
    rbas = rebase -i --autosquash
    # rbfas <commit>
    # 1) commit staged changes as --fixup=<commit>
    # 2) if there are leftover unstaged/untracked changes, add+commit them as "tmp"
    # 3) start interactive rebase at <commit>^ with autosquash
    rbfas = "!f(){ \
rev=\"$1\"; \
test -n \"$rev\" || { echo 'Usage: git rbfas <commit>'; exit 2; }; \
if ! git diff --cached --quiet; then \
    git commit --fixup=\"$rev\" || exit $?; \
else \
    echo 'No staged changes for fixup — skipping fixup commit.'; \
fi; \
if ! git diff --quiet || [ -n \"$(git ls-files --others --exclude-standard)\" ]; then \
    git add -A && git commit -m 'tmp workspace during rebase autosquash' || true; \
else \
    echo 'No leftover changes for tmp — skipping tmp commit.'; \
fi; \
git rebase -i --autosquash \"$rev^\"; \
git lg HEAD -10; \
}; f"
    rbm = rebase --rebase-merges
    rbc = rebase --continue
    rb-abort-commit = "!git restore --merge -- \"$(git rev-parse --show-toplevel)\""
    tmp = "!git add -A && git commit -m 'tmp'"
